{
  "info": {
    "_postman_id": "b3f1a2b0-6a4a-4b8a-9a4a-ventasapi0001",
    "name": "Sistema de Ventas - API REST",
    "description": "Colección de ejemplos de uso de todos los endpoints de la API (clientes, artículos, categorías, ventas y autenticación). El request 'Login' guarda automáticamente el token JWT en la variable de colección {{token}}, que se reutiliza en el resto de los requests mediante el header Authorization.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "clienteId", "value": "1", "type": "string" },
    { "key": "articuloId", "value": "1", "type": "string" },
    { "key": "categoriaId", "value": "1", "type": "string" },
    { "key": "ventaId", "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "Autenticación",
      "item": [
        {
          "name": "Login (credenciales válidas)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('token', body.token);",
                  "    console.log('Token guardado en {{token}}');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Usuario sembrado automáticamente por DataSeeder al arrancar la aplicación."
          }
        },
        {
          "name": "Login (credenciales inválidas -> 401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"clave-incorrecta\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Clientes",
      "item": [
        {
          "name": "Crear cliente",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan Pérez\",\n  \"email\": \"juan.perez@example.com\",\n  \"telefono\": \"555-1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clientes",
              "host": ["{{baseUrl}}"],
              "path": ["clientes"]
            }
          }
        },
        {
          "name": "Listar clientes (paginado)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/clientes?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["clientes"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Obtener cliente por id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/clientes/{{clienteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["clientes", "{{clienteId}}"]
            }
          }
        },
        {
          "name": "Actualizar cliente",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan Pérez Actualizado\",\n  \"email\": \"juan.perez@example.com\",\n  \"telefono\": \"555-5678\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clientes/{{clienteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["clientes", "{{clienteId}}"]
            }
          }
        },
        {
          "name": "Baja lógica de cliente",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/clientes/{{clienteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["clientes", "{{clienteId}}"]
            }
          }
        },
        {
          "name": "Baja física de cliente (falla con 400 si tiene ventas)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/clientes/{{clienteId}}?permanente=true",
              "host": ["{{baseUrl}}"],
              "path": ["clientes", "{{clienteId}}"],
              "query": [{ "key": "permanente", "value": "true" }]
            }
          }
        }
      ]
    },
    {
      "name": "Categorías (extra)",
      "item": [
        {
          "name": "Crear categoría",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Electrónica\",\n  \"descripcion\": \"Artículos electrónicos y accesorios\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/categorias",
              "host": ["{{baseUrl}}"],
              "path": ["categorias"]
            }
          }
        },
        {
          "name": "Listar categorías (paginado)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/categorias?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["categorias"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Artículos",
      "item": [
        {
          "name": "Crear artículo",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigo\": \"ART-001\",\n  \"nombre\": \"Teclado mecánico\",\n  \"descripcion\": \"Teclado mecánico retroiluminado\",\n  \"precio\": 899.99,\n  \"stock\": 25,\n  \"categoriaId\": {{categoriaId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/articulos",
              "host": ["{{baseUrl}}"],
              "path": ["articulos"]
            }
          }
        },
        {
          "name": "Crear artículo con código duplicado (-> 409)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigo\": \"ART-001\",\n  \"nombre\": \"Teclado mecánico (duplicado)\",\n  \"precio\": 500.00,\n  \"stock\": 5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/articulos",
              "host": ["{{baseUrl}}"],
              "path": ["articulos"]
            }
          }
        },
        {
          "name": "Listar artículos (paginado)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/articulos?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["articulos"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Obtener artículo por id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/articulos/{{articuloId}}",
              "host": ["{{baseUrl}}"],
              "path": ["articulos", "{{articuloId}}"]
            }
          }
        },
        {
          "name": "Actualizar artículo",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigo\": \"ART-001\",\n  \"nombre\": \"Teclado mecánico RGB\",\n  \"descripcion\": \"Teclado mecánico retroiluminado RGB\",\n  \"precio\": 949.99,\n  \"stock\": 25,\n  \"categoriaId\": {{categoriaId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/articulos/{{articuloId}}",
              "host": ["{{baseUrl}}"],
              "path": ["articulos", "{{articuloId}}"]
            }
          }
        },
        {
          "name": "Baja lógica de artículo",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/articulos/{{articuloId}}",
              "host": ["{{baseUrl}}"],
              "path": ["articulos", "{{articuloId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Ventas",
      "item": [
        {
          "name": "Registrar venta",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('ventaId', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clienteId\": {{clienteId}},\n  \"detalles\": [\n    { \"articuloId\": {{articuloId}}, \"cantidad\": 2 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/ventas",
              "host": ["{{baseUrl}}"],
              "path": ["ventas"]
            },
            "description": "El total se calcula en el servidor a partir del precio real del artículo; no se envía total en el body."
          }
        },
        {
          "name": "Registrar venta con stock insuficiente (-> 409)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clienteId\": {{clienteId}},\n  \"detalles\": [\n    { \"articuloId\": {{articuloId}}, \"cantidad\": 999999 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/ventas",
              "host": ["{{baseUrl}}"],
              "path": ["ventas"]
            }
          }
        },
        {
          "name": "Listar ventas (paginado)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/ventas?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["ventas"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Listar ventas filtrando por cliente y estado",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/ventas?clienteId={{clienteId}}&estado=ACTIVA",
              "host": ["{{baseUrl}}"],
              "path": ["ventas"],
              "query": [
                { "key": "clienteId", "value": "{{clienteId}}" },
                { "key": "estado", "value": "ACTIVA" }
              ]
            }
          }
        },
        {
          "name": "Listar ventas filtrando por rango de fechas",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/ventas?desde=2026-01-01T00:00:00&hasta=2026-12-31T23:59:59",
              "host": ["{{baseUrl}}"],
              "path": ["ventas"],
              "query": [
                { "key": "desde", "value": "2026-01-01T00:00:00" },
                { "key": "hasta", "value": "2026-12-31T23:59:59" }
              ]
            }
          }
        },
        {
          "name": "Obtener detalle de una venta",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/ventas/{{ventaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["ventas", "{{ventaId}}"]
            }
          }
        },
        {
          "name": "Cancelar venta (repone stock)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/ventas/{{ventaId}}/cancelar",
              "host": ["{{baseUrl}}"],
              "path": ["ventas", "{{ventaId}}", "cancelar"]
            }
          }
        },
        {
          "name": "Cancelar venta ya cancelada (-> 400)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/ventas/{{ventaId}}/cancelar",
              "host": ["{{baseUrl}}"],
              "path": ["ventas", "{{ventaId}}", "cancelar"]
            }
          }
        }
      ]
    },
    {
      "name": "Seguridad",
      "item": [
        {
          "name": "Listar clientes sin token (-> 401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/clientes",
              "host": ["{{baseUrl}}"],
              "path": ["clientes"]
            }
          }
        }
      ]
    }
  ]
}
